# Homebrew configuration
export HOMEBREW_PREFIX="/opt/homebrew"

# Enable Powerlevel10k instant prompt (keep this at the top)
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Powerlevel10k theme
source $HOMEBREW_PREFIX/share/powerlevel10k/powerlevel10k.zsh-theme
typeset -g POWERLEVEL9K_INSTANT_PROMPT=quiet

# zsh-completions
FPATH=$HOMEBREW_PREFIX/share/zsh-completions:$FPATH

# Performance optimizations
# Compile zcompdump if modified, to increase startup speed
autoload -Uz compinit
if [[ -n ~/.zcompdump(#qN.mh+24) ]]; then
  compinit -u
  touch ~/.zcompdump
else
  compinit -C -u
fi

# Cache expensive completions
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path ~/.zsh/cache

# zsh plugins (must be after compinit)
source $HOMEBREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source $HOMEBREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

### Completion configuration
zstyle ':completion:*' special-dirs true
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}' # Case insensitive completion

### Source additional configuration files
# Load custom configurations
for config_file in ~/.{extra,exports,aliases,private}; do
    [[ -r "$config_file" ]] && source "$config_file"
done
unset config_file

### FZF configuration
[[ -f ~/.fzf.zsh ]] && source ~/.fzf.zsh


### Key bindings
bindkey '\t\t' autosuggest-accept

### Path configuration
path=(
  "$HOMEBREW_PREFIX/bin"
  "$HOMEBREW_PREFIX/sbin"
  "/usr/local/bin"
  "/usr/local/sbin"
  $path
)

# Man path
export MANPATH="$HOMEBREW_PREFIX/share/man${MANPATH+:$MANPATH}:"
export INFOPATH="$HOMEBREW_PREFIX/share/info:${INFOPATH:-}"

### Tool configurations
# Z jump configuration
. $HOMEBREW_PREFIX/etc/profile.d/z.sh

# Load Powerlevel10k configuration
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh


# Lazy-load asdf for faster shell startup
asdf() {
  unfunction asdf
  . $HOMEBREW_PREFIX/opt/asdf/libexec/asdf.sh
  asdf "$@"
}
export PATH="${ASDF_DATA_DIR:-$HOME/.asdf}/shims:$PATH"

